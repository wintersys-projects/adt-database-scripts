CREATE USER XXXXDB_UXXXX WITH ENCRYPTED PASSWORD 'XXXXDB_PXXXX';
ALTER USER XXXXDB_UXXXX;
CREATE DATABASE XXXXDB_NXXXX WITH OWNER XXXXDB_UXXXX ENCODING 'UTF8' LC_COLLATE = 'en_US.UTF-8' LC_CTYPE = 'en_US.UTF-8' TEMPLATE template0;
CREATE DATABASE XXXXDB_NXXXX WITH OWNER XXXXDB_UXXXX ENCODING 'UTF8' LC_COLLATE = 'C.UTF-8' LC_CTYPE = 'C.UTF-8' TEMPLATE template0;
GRANT ALL PRIVILEGES ON DATABASE XXXXDB_NXXXX to XXXXDB_UXXXX;
ALTER USER postgres PASSWORD 'XXXXDB_PXXXX';
CREATE EXTENSION pg_trgm;
